# .env.local — ใส่ key จริงที่นี่ อย่า commit ไฟล์นี้

# ---- Groq (ฟรี ไม่ต้องบัตรเครดิต) ----
# สมัครที่ console.groq.com
# ใส่หลาย key คั่นด้วย comma → round-robin อัตโนมัติ
GROQ_API_KEYS=gsk_xxxx,gsk_yyyy,gsk_zzzz

# ---- Google Gemini Flash (ฟรี) ----
# สมัครที่ aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza_xxxx

# ---- Cloudflare Worker (ถ้าใช้) ----
# URL ของ Worker ที่ deploy แล้ว
# CLOUDFLARE_WORKER_URL=https://dharma-lb.yourname.workers.dev

# ---- Vercel backend URLs (ใส่ใน Cloudflare Worker env) ----
# BACKEND_URLS=https://dharma1.vercel.app,https://dharma2.vercel.app
