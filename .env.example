# .env.local — ใส่ key จริงที่นี่ อย่า commit ไฟล์นี้

# ============ AI PROVIDERS ============
# ลำดับการลอง (default: azure,groq,gemini) — ตัวไหนไม่ตั้ง key จะข้ามอัตโนมัติ
PROVIDER_ORDER=azure,groq,gemini

# ---- Azure OpenAI (ใช้ Azure student credit $100) ----
# Portal → Azure OpenAI → Deploy gpt-4o-mini → เอาค่ามาใส่
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=your_azure_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ---- Groq (ฟรี ไม่ต้องบัตร) — console.groq.com ----
GROQ_API_KEYS=gsk_xxxx,gsk_yyyy

# ---- Gemini Flash (ฟรี) — aistudio.google.com ----
GEMINI_API_KEY=AIza_xxxx

# ============ CACHE + RATE LIMIT (shared) ============
# Upstash Redis (ฟรี 10k cmd/วัน) — console.upstash.com
# จำเป็นสำหรับ cache/rate-limit ที่ทำงานข้าม serverless instance จริง
# ถ้าไม่ตั้ง → fallback เป็น in-memory (ใช้ได้แต่ cache hit ต่ำกว่า)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# ============ CLOUDFLARE (optional) ============
# CLOUDFLARE_WORKER_URL=https://dharma-lb.yourname.workers.dev
